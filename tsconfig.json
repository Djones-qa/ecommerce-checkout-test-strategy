{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020", "DOM"],
    "types": ["node", "jest"],
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "outDir": "dist",
    "rootDir": ".",
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@types/*": ["src/types/*"],
      "@mocks/*": ["src/mocks/*"],
      "@utils/*": ["src/utils/*"]
    }
  },
  "include": ["src/**/*", "contract-tests/**/*", "visual-tests/**/*"],
  "exclude": ["node_modules", "dist", "cypress"]
}
